# ── Autonomous AI Agent — Environment Variables ──────────────────────────────

# Choose: auto, groq, gemini, ollama, or mock.
# "auto" uses an available cloud key, otherwise deterministic demo mode.
LLM_PROVIDER=auto

# Optional cloud API keys. Never commit real secrets.
# Groq Cloud keys: https://console.groq.com/keys
# Google Gemini keys: https://aistudio.google.com/app/apikey
GROQ_API_KEY=
# or
# GEMINI_API_KEY=AIza_your_gemini_key_here

# Optional: Force the provider explicitly (groq or gemini)
# LLM_PROVIDER=groq

# Google Cloud project (used if accessing Gemini via Vertex AI)
GCP_PROJECT_ID=
GCP_PROJECT_NUMBER=

# Optional: Gemini model to use
GEMINI_MODEL=gemini-2.0-flash

# Optional: Groq model to use
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: fully local LLM
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_NUM_PREDICT=450

# Optional: Directory where generated .docx files are saved
OUTPUT_DIR=output

# Optional: Maximum number of reflection-triggered regenerations (0 or 1)
MAX_REFLECTION_RETRIES=1

# Retry transient LLM failures, then optionally use deterministic demo fallback
LLM_MAX_RETRIES=2
LLM_TIMEOUT_SECONDS=60
ALLOW_MOCK_FALLBACK=true

# Optional: Logging level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
